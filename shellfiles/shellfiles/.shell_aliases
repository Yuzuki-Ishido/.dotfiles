# creating aliases to use in terminal, streamlined for personal preferences
# meant to be sourced in .zshrc file

# REPOSITORIES
alias home="cd $MYHOME"
alias prg="cd $PROGRAMMING"
alias dotfiles="cd $DOTFILES"

# TERMINAL COMMANDS
alias lsal="ls -al"
alias python="python3"
alias vim="nvim"

# FZF COMMANDS
alias fsearch='fzf --preview="bat --color=always {}"'
alias fvim='nvim $(fzf --preview="bat --color=always {}")'

# TMUX COMMANDS
alias tka="tmux kill-server"
alias tks="tmux kill-session -t"
alias tls="tmux ls"
alias tnew="tmux new -s"
alias tatt="tmux attach -t"

# PROJECT COMMANDS
alias save="cd $PROGRAMMING/gen5-save-editor"
alias unfair="cd $PROGRAMMING/unfair-flips-analysis/"
